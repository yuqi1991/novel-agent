# Optional. Defaults to file:./user_data/novel-agent.db
DATABASE_URL=file:./user_data/novel-agent.db

# Use stub for deterministic local testing; use pi for real LLM-backed play.
NOVEL_AGENT_RUNTIME=stub

# Optional. Defaults to ./user_data
NOVEL_AGENT_USER_DATA_DIR=user_data

# Optional Pi runtime overrides. Normally leave these unset and edit user_data/config.yaml.
# NOVEL_AGENT_PI_AUTH_PATH=user_data/providers/auth.json
# NOVEL_AGENT_PI_MODELS_PATH=user_data/providers/models.json
# NOVEL_AGENT_PI_NO_TOOLS=true
